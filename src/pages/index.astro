---
import Layout from '../layouts/Layout.astro';

const features = [
  { icon: '🍺', title: 'Cerveja Gelada',       desc: 'Diversas marcas sempre na temperatura certa. Latinha, long neck, garrafa — você escolhe.',  color: 'gold'  },
  { icon: '🚬', title: 'Tabacaria',             desc: 'Cigarros, charutos, narguilé e acessórios. Tudo que você precisa em um só lugar.',           color: 'green' },
  { icon: '🍽️', title: 'Porções',               desc: 'Calabresa acebolada, batata frita, frango e muito mais. Porções generosas para a galera.',    color: 'gold'  },
  { icon: '🔥', title: 'Churrasco',             desc: 'Carne fresca na brasa em todos os dias de jogo do Brasil. Linguiça, frango e muito mais.',     color: 'red'   },
  { icon: '🎵', title: 'Pagode de Esquenta',    desc: 'Show ao vivo antes de cada jogo para esquentar a torcida. Samba e pagode raiz garantidos.',    color: 'green' },
  { icon: '🛡️', title: 'Ambiente Seguro',       desc: 'Espaço familiar, confortável e monitorado. Traga sua família e curta com tranquilidade.',     color: 'gold'  },
];
---

<Layout>

  <!-- ══════════════════════════════════════════ NAV ══════ -->
  <nav class="nav">
    <a href="#inicio" class="nav-logo">
      <img src="/logo.jpeg" alt="Logo Ponto Amigo" />
      <div>
        <span class="nav-brand">Ponto Amigo</span>
        <small>Conveniência</small>
      </div>
    </a>

    <ul class="nav-links">
      <li><a href="#jogo">Próximo Jogo</a></li>
      <li><a href="#ofertas">O Que Temos</a></li>
      <li><a href="#combo">Combo</a></li>
      <li><a href="#local">Local</a></li>
    </ul>

    <a class="nav-insta" href="https://www.instagram.com/pontoamigoconveniencia_/" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
      </svg>
      <span>Seguir</span>
    </a>
  </nav>

  <!-- ══════════════════════════════════════════ HERO ══════ -->
  <section class="hero" id="inicio">
    <!-- Background blobs -->
    <div class="hero-blob hero-blob--green"></div>
    <div class="hero-blob hero-blob--gold"></div>
    <!-- Dot grid overlay -->
    <div class="hero-grid"></div>

    <div class="hero-inner">
      <p class="eyebrow hero-eyebrow">Conveniência Ponto Amigo &middot; Sorocaba, SP</p>

      <h1 class="hero-title display">
        <span class="hero-line hero-line--1">A Copa</span>
        <span class="hero-line hero-line--2 text-gold">É Aqui!</span>
      </h1>

      <p class="hero-sub">
        Churrasco na brasa &bull; Cerveja gelada &bull; Pagode ao vivo<br/>
        Cada jogo do Brasil você assiste com a galera
      </p>

      <div class="hero-actions">
        <a href="#jogo"    class="btn btn--primary">Ver próximo jogo</a>
        <a href="#ofertas" class="btn btn--ghost">O que temos</a>
      </div>
    </div>

    <a href="#jogo" class="hero-scroll" aria-label="Rolar para baixo">
      <span>Rolar</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </a>
  </section>

  <!-- ══════════════════════════════════════════ TICKER ══════ -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {Array.from({length: 2}).map(() => (
        <div class="ticker-set">
          <span>⚽ Brasil na Copa 2026</span>
          <span class="ticker-dot">★</span>
          <span>🍺 Cerveja Gelada</span>
          <span class="ticker-dot">★</span>
          <span>🔥 Churrasco na Brasa</span>
          <span class="ticker-dot">★</span>
          <span>🎵 Pagode ao Vivo</span>
          <span class="ticker-dot">★</span>
          <span>🛡️ Ambiente Seguro</span>
          <span class="ticker-dot">★</span>
          <span>🚬 Tabacaria Completa</span>
          <span class="ticker-dot">★</span>
          <span>🍽️ Porções Generosas</span>
          <span class="ticker-dot">★</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ══════════════════════════════════════════ NEXT GAME ══════ -->
  <section class="next-game" id="jogo">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Próximo Jogo</p>
        <h2 class="display section-title">Hoje Tem Jogo!</h2>
        <p class="section-sub">Venha assistir ao vivo com a galera</p>
      </div>

      <div class="match-card glow-green" data-reveal data-delay="150">
        <div class="match-bg">
          <img src="/2.jpeg" alt="Brasil x Marrocos" />
        </div>
        <div class="match-overlay"></div>

        <div class="match-body">
          <p class="match-event eyebrow">Copa 2026 &middot; Fase de Grupos</p>

          <div class="match-teams">
            <div class="team">
              <div class="team-flag">🇧🇷</div>
              <span class="team-name display">BRASIL</span>
            </div>
            <div class="match-vs display">×</div>
            <div class="team">
              <div class="team-flag">🇲🇦</div>
              <span class="team-name display">MARROCOS</span>
            </div>
          </div>

          <div class="countdown" id="countdown">
            <div class="cd-unit">
              <span class="cd-num display" id="cd-d">--</span>
              <span class="cd-label">dias</span>
            </div>
            <div class="cd-sep display">:</div>
            <div class="cd-unit">
              <span class="cd-num display" id="cd-h">--</span>
              <span class="cd-label">horas</span>
            </div>
            <div class="cd-sep display">:</div>
            <div class="cd-unit">
              <span class="cd-num display" id="cd-m">--</span>
              <span class="cd-label">min</span>
            </div>
            <div class="cd-sep display">:</div>
            <div class="cd-unit">
              <span class="cd-num display" id="cd-s">--</span>
              <span class="cd-label">seg</span>
            </div>
          </div>

          <div class="match-meta">
            <span>📅 Sáb · 13/06/2026</span>
            <span>⏰ 19h00</span>
            <span>📍 Conveniência Ponto Amigo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ FEATURES ══════ -->
  <section class="features" id="ofertas">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">O Que Temos</p>
        <h2 class="display section-title">Por Que Vir ao<br/><span class="text-gold">Ponto Amigo?</span></h2>
        <p class="section-sub">Tudo que você precisa para curtir a Copa com estilo</p>
      </div>

      <div class="features-grid" data-stagger>
        {features.map(f => (
          <div class={`feature-card feature-card--${f.color}`} data-reveal="scale">
            <div class="feature-icon">{f.icon}</div>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ COMBO ══════ -->
  <section class="combo" id="combo">
    <div class="container">
      <div class="combo-inner">
        <div class="combo-media" data-reveal="left">
          <div class="combo-img-wrap glow-green">
            <img src="/1.jpeg" alt="Combo da Galera — Porção calabresa + batata + 4 cervejas" />
            <div class="combo-badge display">Promoção<br/>especial</div>
          </div>
        </div>

        <div class="combo-text" data-reveal="right">
          <p class="eyebrow">Combo especial</p>
          <h2 class="display combo-title">Combo da<br/><span class="text-gold">Galera!</span></h2>
          <p class="combo-tagline">Torcida reunida pede promoção especial!</p>

          <ul class="combo-list">
            <li>
              <svg viewBox="0 0 20 20" fill="currentColor"><circle cx="10" cy="10" r="10"/></svg>
              Porção de calabresa acebolada
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="currentColor"><circle cx="10" cy="10" r="10"/></svg>
              Batata frita crocante
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="currentColor"><circle cx="10" cy="10" r="10"/></svg>
              4 cervejas geladas
            </li>
          </ul>

          <div class="combo-price">
            <span class="price-label">por apenas</span>
            <span class="price-value display">R$ 99<span class="price-cents">,90</span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ GALLERY ══════ -->
  <section class="gallery" id="galeria">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Galeria</p>
        <h2 class="display section-title">Vem pra<br/><span class="text-gold">Copa!</span></h2>
      </div>
      <div class="gallery-grid" data-stagger>
        <div class="gallery-item gallery-item--large" data-reveal="left">
          <img src="/2.jpeg" alt="Hoje tem Jogo – Brasil x Marrocos" />
          <div class="gallery-overlay">
            <span class="display">Hoje Tem Jogo</span>
          </div>
        </div>
        <div class="gallery-item" data-reveal="right">
          <img src="/1.jpeg" alt="Combo da Galera" />
          <div class="gallery-overlay">
            <span class="display">Combo da Galera</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ LOCATION ══════ -->
  <section class="location" id="local">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Onde Estamos</p>
        <h2 class="display section-title">Venha nos<br/><span class="text-gold">Visitar</span></h2>
        <p class="section-sub">Te esperamos em Sorocaba, SP</p>
      </div>

      <div class="location-grid" data-stagger>
        <div class="loc-card" data-reveal="left">
          <div class="loc-card-icon">📍</div>
          <h3 class="loc-card-title display">Endereço</h3>
          <address>
            Av. Três de Março, 6015<br/>
            Jardim Residencial Villa Amato<br/>
            Sorocaba – SP · 18087-180
          </address>
          <a
            class="btn btn--outline btn--sm"
            href="https://maps.google.com/?q=Av.+Tres+de+Marco+6015+Sorocaba+SP"
            target="_blank"
            rel="noopener"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            Ver no mapa
          </a>
        </div>

        <div class="loc-card" data-reveal>
          <div class="loc-card-icon">🕐</div>
          <h3 class="loc-card-title display">Horários</h3>
          <table class="hours-table">
            <tr><td>Segunda – Sábado </td><td>07h – 21h</td></tr>
            <tr><td>Domingo</td>       <td>07h – 17h</td></tr>
            <tr class="hours-special"><td>Dias de Jogo</td><td>Até acabar! 🎉</td></tr>
          </table>
        </div>

        <div class="loc-card loc-card--highlight" data-reveal="right">
          <div class="loc-card-icon">📱</div>
          <h3 class="loc-card-title display">Redes Sociais</h3>
          <p>Acompanhe nossa programação, promoções e notícias da Copa em primeira mão.</p>
          <a
            class="btn btn--primary"
            href="https://www.instagram.com/pontoamigoconveniencia_/"
            target="_blank"
            rel="noopener"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            @pontoamigoconveniencia_
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ FOOTER ══════ -->
  <footer class="footer">
    <div class="footer-inner container">
      <div class="footer-brand">
        <img src="/logo.jpeg" alt="Logo Ponto Amigo" />
        <div>
          <p class="display footer-name">Ponto Amigo</p>
          <p class="footer-tag">Conveniência · Sorocaba, SP</p>
        </div>
      </div>

      <p class="footer-copy">
        © 2026 Conveniência Ponto Amigo &mdash; feito com ❤️ para a torcida
      </p>
    </div>
  </footer>

</Layout>

<style>
  /* ════ CONTAINER ════ */
  .container {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: clamp(20px, 5vw, 48px);
  }

  /* ════ SECTION HEADER ════ */
  .section-header { text-align: center; margin-bottom: 56px; }

  .section-title {
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    margin-top: 10px;
    color: var(--text);
  }

  .section-sub {
    margin-top: 12px;
    color: var(--text2);
    font-size: 1rem;
  }

  /* ════ BUTTONS ════ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 14px 30px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), background 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn--primary {
    background: var(--gold);
    color: #080808;
    box-shadow: 0 4px 24px rgba(255,208,0,.3);
  }
  .btn--primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 36px rgba(255,208,0,.45);
  }

  .btn--ghost {
    background: rgba(255,255,255,.06);
    color: var(--text);
    border: 1px solid rgba(255,255,255,.15);
  }
  .btn--ghost:hover {
    background: rgba(255,255,255,.12);
    transform: translateY(-2px);
  }

  .btn--outline {
    background: transparent;
    color: var(--gold);
    border: 1.5px solid rgba(255,208,0,.5);
  }
  .btn--outline:hover {
    background: var(--gold-dim);
    transform: translateY(-2px);
  }

  .btn--sm { font-size: 0.8rem; padding: 10px 22px; }

  /* ════ NAV ════ */
  .nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(20px, 5vw, 48px);
    transition: background 0.4s, backdrop-filter 0.4s, border-color 0.4s, padding 0.4s;
    border-bottom: 1px solid transparent;
  }

  .nav--scrolled {
    background: rgba(9,9,9,.9);
    backdrop-filter: blur(16px);
    border-color: rgba(255,255,255,.07);
    padding-block: 10px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .nav-logo img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--gold);
  }

  .nav-brand {
    display: block;
    font-family: 'Bebas Neue', cursive;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    color: var(--gold);
    line-height: 1.1;
  }

  .nav-logo small {
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text2);
  }

  .nav-links {
    display: flex;
    gap: 28px;
    list-style: none;
  }

  .nav-links a {
    color: var(--text2);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }

  .nav-insta {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--gold);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 700;
    border: 1.5px solid rgba(255,208,0,.35);
    padding: 7px 16px;
    border-radius: 100px;
    transition: background 0.2s;
  }
  .nav-insta svg { width: 16px; height: 16px; }
  .nav-insta:hover { background: var(--gold-dim); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-insta span { display: none; }
    .nav-insta { padding: 8px; border-radius: 50%; }
    .nav-insta svg { width: 20px; height: 20px; }
  }

  /* ════ HERO ════ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 100px clamp(20px, 5vw, 48px) 80px;
  }

  /* dot grid */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.07) 1px, transparent 1px);
    background-size: 36px 36px;
    pointer-events: none;
  }

  /* animated blobs */
  .hero-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
    filter: blur(80px);
  }

  .hero-blob--green {
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(27,94,32,.5) 0%, transparent 70%);
    top: -200px;
    left: -200px;
    animation: blobDrift 10s ease-in-out infinite alternate;
  }

  .hero-blob--gold {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,208,0,.12) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    animation: blobDrift 7s ease-in-out infinite alternate-reverse;
  }

  @keyframes blobDrift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(40px, 30px) scale(1.12); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
  }

  .hero-eyebrow {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.8s 0.1s var(--ease) forwards;
    margin-bottom: 18px;
  }

  .hero-title {
    font-size: clamp(4.5rem, 18vw, 12rem);
  }

  .hero-line {
    display: block;
    opacity: 0;
    transform: translateY(40px);
  }

  .hero-line--1 { animation: fadeUp 0.9s 0.3s var(--ease) forwards; }
