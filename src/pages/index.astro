---
import Layout from '../layouts/Layout.astro';
import HeroEvent from '../components/HeroEvent.jsx';
import { EVENTOS } from '../data/eventos.js';

const TYPE_CONFIG = {
  copa:      { label: "Copa do Mundo 2026", emoji: "🏆", color: "#00C853", dim: "rgba(0,200,83,0.10)" },
  musica:    { label: "Música ao Vivo",     emoji: "🎵", color: "#FF6B2B", dim: "rgba(255,107,43,0.10)" },
  churrasco: { label: "Churrasco",          emoji: "🔥", color: "#E24B4A", dim: "rgba(226,75,74,0.10)" },
  especial:  { label: "Evento Especial",    emoji: "⭐", color: "#FFD600", dim: "rgba(255,214,0,0.10)" },
};

const MONTHS_SHORT = ["JAN","FEV","MAR","ABR","MAI","JUN","JUL","AGO","SET","OUT","NOV","DEZ"];
const DAYS_SHORT   = ["DOM","SEG","TER","QUA","QUI","SEX","SÁB"];

function parseEvent(e: { id: number; titulo: string; subtitulo?: string; data: string; hora: string; tipo: string; descricao: string; badge?: string; imagem?: string }) {
  const d = new Date(`${e.data}T${e.hora}:00-03:00`);
  const cfg = TYPE_CONFIG[e.tipo as keyof typeof TYPE_CONFIG] ?? TYPE_CONFIG.especial;
  return {
    ...e,
    dateObj: d,
    isPast:       d < new Date(),
    day:          d.getDate(),
    monthShort:   MONTHS_SHORT[d.getMonth()],
    weekdayShort: DAYS_SHORT[d.getDay()],
    horaDisplay:  e.hora.replace(':00','h').replace(':30','h30'),
    cfg,
  };
}

const events = EVENTOS.map(parseEvent).sort((a, b) => a.dateObj - b.dateObj);
const next   = events.find(e => !e.isPast) ?? events.at(-1);
---

<Layout
  title="Conveniência Ponto Amigo — Agenda de Eventos"
  description="Agenda de eventos da Conveniência Ponto Amigo em Sorocaba. Jogos do Brasil, música ao vivo, churrasco e mais. Entrada franca."
>

<!-- ═══════════════ NAV ═══════════════ -->
<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/logo.jpeg" alt="Ponto Amigo" />
    <span class="nav-brand">Ponto Amigo</span>
  </a>
  <div class="nav-links">
    <a href="#agenda">Agenda</a>
    <a href="#local">Local</a>
  </div>
</nav>

<!-- ═══════════════ HERO (React — dinâmico no browser) ═══════════════ -->
<HeroEvent client:load />

<!-- ═══════════════ AGENDA ═══════════════ -->
<section id="agenda" class="agenda-section">

  <div class="section-header">
    <span class="eyebrow" data-reveal="fade">Calendário</span>
    <h2 class="section-title display" data-reveal="title">Agenda de Eventos</h2>
    <p class="section-sub" data-reveal="slice">Cada fim de semana tem uma surpresa. Fique de olho.</p>
  </div>

  <div class="events-list" data-stagger>
    {events.map((e) => (
      <article
        class={`event-row ${e.isPast ? 'event-past' : ''} ${e.id === next?.id ? 'event-next' : ''} ${e.imagem ? 'event-has-img' : ''}`}
        style={`--ec: ${e.cfg.color}; --ed: ${e.cfg.dim};`}
        data-reveal="up"
      >
        <div class="event-date">
          <span class="event-day">{e.day}</span>
          <span class="event-month">{e.monthShort}</span>
          <span class="event-weekday">{e.weekdayShort}</span>
        </div>

        <div class="event-divider"></div>

        <div class="event-content">
          <div class="event-chip" style={`color: ${e.cfg.color}; background: ${e.cfg.dim}; border-color: ${e.cfg.color}22;`}>
            {e.cfg.emoji} {e.cfg.label}
          </div>
          <h3 class="event-title display">{e.titulo}</h3>
          {e.subtitulo && <p class="event-subtitle">{e.subtitulo}</p>}
          <p class="event-desc">{e.descricao}</p>
          <div class="event-footer">
            <span class="event-time">⏰ {e.horaDisplay}</span>
            {e.badge && <span class="event-badge">{e.badge}</span>}
            {e.id === next?.id && !e.isPast && (
              <span class="event-next-label">Próximo evento</span>
            )}
          </div>
        </div>

        {e.imagem && (
          <div class="event-img-wrap">
            <img src={e.imagem} alt={e.titulo} />
          </div>
        )}
      </article>
    ))}
  </div>

</section>

<!-- ═══════════════ LOCAL ═══════════════ -->
<section id="local" class="local-section">
  <div class="local-inner">
    <div class="local-info" data-reveal="left">
      <span class="eyebrow">Onde estamos</span>
      <h2 class="display local-title">Conveniência<br/>Ponto Amigo</h2>
      <div class="local-address">
        <p>Av. Três de Março, 6015</p>
        <p>Jardim Residencial Villa Amato</p>
        <p>Sorocaba — SP</p>
      </div>
      <div class="local-btns">
        <a
          href="https://maps.google.com/?q=Av.+Três+de+Março,+6015+Sorocaba+SP"
          target="_blank"
          rel="noopener noreferrer"
          class="local-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Ver no Maps
        </a>
        <a
          href="https://g.page/r/Cf9uLHyjOAAEEAE/review"
          target="_blank"
          rel="noopener noreferrer"
          class="local-btn local-btn--review"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          Avaliar no Google
        </a>
      </div>
    </div>
    <div class="local-hours" data-reveal="right">
      <span class="eyebrow">Funcionamento</span>
      <div class="hours-grid">
        <div class="hours-row">
          <span>Seg – Sáb</span>
          <span>07h – 21h</span>
        </div>
        <div class="hours-row">
          <span>Dom e feriados</span>
          <span>07h – 17h</span>
        </div>
        <div class="hours-row hours-row--highlight">
          <span>Dias de evento</span>
          <span>até o último cliente</span>
        </div>
      </div>
      <p class="hours-note">Em dias de jogo e eventos especiais ficamos abertos enquanto tiver movimento.</p>
    </div>
  </div>

  <!-- Mapa gratuito via iframe -->
  <div class="local-map-wrap" data-reveal="up">
    <iframe
      class="local-map-iframe"
      src="https://maps.google.com/maps?q=-23.448514272038203,-47.37712692209014&z=15&output=embed"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Localização Conveniência Ponto Amigo"
      allowfullscreen
    ></iframe>
  </div>
</section>

<!-- ═══════════════ FOOTER ═══════════════ -->
<footer class="footer">
  <img src="/logo.jpeg" alt="Ponto Amigo" class="footer-logo" />
  <p>© 2026 Conveniência Ponto Amigo · Sorocaba, SP</p>
  <p class="footer-tagline">O ponto onde todo mundo vira amigo.</p>
  <a
    href="https://g.page/r/Cf9uLHyjOAAEEAE/review"
    target="_blank"
    rel="noopener noreferrer"
    class="footer-review"
  >
    ⭐ Deixe sua avaliação no Google
  </a>
</footer>

</Layout>

<style is:global>
/* ═══ HERO (global — rendered by React, scoped CSS won't reach it) ═══ */
.hero {
  min-height: 100svh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 100px 40px 60px;
}
.hero-bg-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 110% 90% at 75% 10%,  var(--hero-dim) 0%, transparent 55%),
    radial-gradient(ellipse  60% 50% at 20% 85%,  var(--hero-dim) 0%, transparent 60%),
    radial-gradient(ellipse  80% 60% at 50% 50%,  var(--hero-dim) 0%, transparent 70%),
    radial-gradient(ellipse  35% 30% at  5% 10%,  rgba(255,208,0,0.05) 0%, transparent 55%);
  pointer-events: none;
}
.hero-inner {
  max-width: 760px;
  margin: 0 auto;
  width: 100%;
  position: relative;
  z-index: 1;
  animation: heroIn 1.1s cubic-bezier(0.16, 1, 0.3, 1) both;
}
@keyframes heroIn {
  from { opacity: 0; transform: translateY(44px); filter: blur(10px); }
  to   { opacity: 1; transform: none; filter: none; }
}
.hero-flyer {
  animation: flyerIn 1.3s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
}
@keyframes flyerIn {
  from { opacity: 0; transform: translateY(-40%) rotate(6deg) scale(0.92); filter: blur(8px); }
  to   { opacity: 1; transform: translateY(-50%) rotate(2deg) scale(1); filter: none; }
}
.hero-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  border: 1px solid;
  border-radius: 50px;
  padding: 6px 14px;
  margin-bottom: 22px;
}
.hero-title {
  font-size: clamp(56px, 10vw, 110px);
  color: #fff;
  margin-bottom: 10px;
  text-shadow: 0 4px 40px rgba(0,0,0,0.6);
}
.hero-sub {
  font-size: 17px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 18px;
  font-weight: 400;
}
.hero-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.6);
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.hero-meta .dot { color: rgba(255,255,255,0.2); }
.hero-desc {
  font-size: 14px;
  color: rgba(255,255,255,0.45);
  max-width: 480px;
  line-height: 1.7;
  margin-top: -8px;
}
.hero-badge-wrap { margin-top: 20px; }
.hero-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 6px 16px;
  border-radius: 50px;
}
.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 36px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  transition: color 0.2s;
  animation: heroFloat 2.5s ease-in-out infinite;
}
.hero-cta:hover { color: rgba(255,255,255,0.8); }
@keyframes heroFloat {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(6px); }
}
.hero-flyer {
  position: absolute;
  right: clamp(20px, 6vw, 100px);
  top: 50%;
  transform: translateY(-50%) rotate(2deg);
  width: clamp(200px, 26vw, 340px);
  pointer-events: none;
  z-index: 0;
}
.hero-flyer img {
  width: 100%;
  border-radius: 18px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.06);
  display: block;
}
@media (max-width: 680px) {
  .hero { padding: 90px 24px 50px; }
  .hero-flyer { display: none; }
}
</style>

<style>
/* ═══ NAV ═══ */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 40px;
  transition: background 0.3s, backdrop-filter 0.3s, padding 0.3s;
}
.nav--scrolled {
  background: rgba(9,9,9,0.92);
  backdrop-filter: blur(16px);
  padding: 12px 40px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-logo img {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  object-fit: cover;
  border: 1.5px solid rgba(255,208,0,0.3);
}
.nav-brand {
  font-size: 13px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 28px;
}
.nav-links a {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  transition: color 0.15s;
}
.nav-links a:hover { color: #fff; }

/* ═══ AGENDA ═══ */
.agenda-section {
  padding: 100px 40px;
  max-width: 860px;
  margin: 0 auto;
}
.section-header {
  margin-bottom: 56px;
}
.section-header .eyebrow {
  display: block;
  margin-bottom: 10px;
  transition-delay: 0ms !important;
}
.section-header .section-title {
  transition-delay: 80ms !important;
}
.section-header .section-sub {
  transition-delay: 180ms !important;
}
.section-title {
  font-size: clamp(44px, 7vw, 72px);
  color: #fff;
  margin: 8px 0 12px;
  line-height: 1;
}
.section-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.35);
}
.events-list {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.event-row {
  display: grid;
  grid-template-columns: 76px 1px 1fr;
  gap: 0 28px;
  padding: 32px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  align-items: start;
  transition: background 0.3s, transform 0.35s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s;
  border-radius: 4px;
  position: relative;
}
.event-row::before {
  content: '';
  position: absolute;
  left: -16px;
  top: 0; bottom: 0;
  width: 2px;
  background: var(--ec, transparent);
  border-radius: 2px;
  transform: scaleY(0);
  transform-origin: bottom;
  transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
}
.event-row:hover {
  background: linear-gradient(90deg, rgba(var(--ec-rgb, 255,255,255), 0.04) 0%, transparent 60%);
  transform: translateX(8px);
  box-shadow: -3px 0 24px -8px var(--ec, transparent);
}
.event-row:hover::before { transform: scaleY(1); }
.event-row:last-child { border-bottom: none; }
.event-past { opacity: 0.28; }
.event-next .event-day { color: var(--ec); }

.event-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 4px;
}
.event-day {
  font-family: 'Bebas Neue', cursive;
  font-size: 52px;
  color: #fff;
  line-height: 1;
  letter-spacing: 1px;
}
.event-month {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  margin-top: -2px;
}
.event-weekday {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  color: rgba(255,255,255,0.2);
  text-transform: uppercase;
  margin-top: 4px;
}
.event-divider {
  width: 1px;
  background: rgba(255,255,255,0.08);
  align-self: stretch;
  margin: 4px 0;
  position: relative;
}
.event-divider::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 2px;
  height: 40%;
  background: var(--ec, rgba(255,255,255,0.3));
  transform: translateX(-0.5px);
  border-radius: 2px;
}
.event-content { padding-top: 2px; }
.event-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  border: 1px solid;
  border-radius: 50px;
  padding: 4px 10px;
  margin-bottom: 10px;
}
.event-title {
  font-size: clamp(28px, 4vw, 42px);
  color: #fff;
  line-height: 1;
  margin-bottom: 6px;
}
.event-subtitle {
  font-size: 14px;
  color: rgba(255,255,255,0.45);
  margin-bottom: 10px;
}
.event-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.35);
  line-height: 1.65;
  max-width: 480px;
  margin-bottom: 16px;
}
.event-footer {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.event-time {
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
}
.event-badge {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--ec);
  color: #000;
  padding: 3px 10px;
  border-radius: 50px;
}
/* Event image */
.event-has-img {
  grid-template-columns: 76px 1px 1fr auto;
}
.event-img-wrap {
  width: clamp(100px, 14vw, 160px);
  align-self: center;
  border-radius: 12px;
  overflow: hidden;
  flex-shrink: 0;
}
.event-img-wrap img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.07);
}

.event-next-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ec);
  border: 1px solid var(--ec);
  padding: 3px 10px;
  border-radius: 50px;
  opacity: 0.7;
}

/* ═══ LOCAL ═══ */
.local-section {
  background: rgba(255,255,255,0.025);
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  padding: 80px 40px;
}
.local-inner {
  max-width: 860px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}
.local-title {
  font-size: clamp(36px, 5vw, 58px);
  color: #fff;
  margin: 8px 0 22px;
  line-height: 1;
}
.local-address { margin-bottom: 28px; }
.local-address p {
  font-size: 15px;
  color: rgba(255,255,255,0.5);
  line-height: 1.9;
}
.local-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.local-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  text-decoration: none;
  border: 1px solid rgba(255,208,0,0.25);
  padding: 10px 20px;
  border-radius: 50px;
  transition: background 0.15s, border-color 0.15s;
}
.local-btn:hover {
  background: rgba(255,208,0,0.08);
  border-color: rgba(255,208,0,0.5);
}
.local-btn--review {
  color: #fff;
  border-color: rgba(255,255,255,0.15);
}
.local-btn--review:hover {
  background: rgba(255,255,255,0.06);
  border-color: rgba(255,255,255,0.35);
}
.hours-grid {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 16px;
}
.hours-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  font-size: 14px;
}
.hours-row span:first-child { color: rgba(255,255,255,0.5); }
.hours-row span:last-child  { color: #fff; font-weight: 600; }
.hours-row--highlight span:first-child { color: var(--gold); }
.hours-row--highlight span:last-child  { color: var(--gold); font-style: italic; }
.hours-note {
  font-size: 11px;
  color: rgba(255,255,255,0.2);
  margin-top: 16px;
  line-height: 1.6;
}

/* ═══ MAPA ═══ */
.local-map-wrap {
  max-width: 860px;
  margin: 48px auto 0;
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.07);
  height: 380px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.5);
  position: relative;
}
.local-map-iframe {
  width: 100%;
  height: 100%;
  border: none;
  display: block;
  /* dark mode: inverte cores e corrige matiz — ruas escuras, água escura */
  filter: invert(92%) hue-rotate(180deg) saturate(0.85) brightness(0.9);
}
@media (max-width: 680px) {
  .local-map-wrap { height: 280px; margin-top: 36px; border-radius: 12px; }
}

/* ═══ FOOTER ═══ */
.footer {
  padding: 48px 40px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
.footer-logo {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  object-fit: cover;
  opacity: 0.4;
  margin-bottom: 4px;
}
.footer p {
  font-size: 11px;
  color: rgba(255,255,255,0.2);
  letter-spacing: 0.04em;
}
.footer-tagline {
  color: rgba(255,255,255,0.12) !important;
  font-style: italic;
}
.footer-review {
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,208,0,0.4);
  text-decoration: none;
  letter-spacing: 0.06em;
  margin-top: 6px;
